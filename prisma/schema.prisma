generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Single-user data store keyed by a client-generated UUID
// (stored in localStorage as campus_coach_user_id)
model UserData {
  id        String   @id
  plan      Json     // TrainingPlan (includes UserProfile + Session[])
  updatedAt DateTime @updatedAt
}
